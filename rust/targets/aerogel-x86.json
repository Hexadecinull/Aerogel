{
    "llvm-target": "i686-unknown-none-elf",
    "data-layout": "e-m:e-p:32:32-f64:32:64-f80:32-n8:16:32-S128",
    "arch": "x86",
    "target-endian": "little",
    "target-pointer-width": 32,
    "target-c-int-width": 32,
    "os": "none",
    "env": "",
    "vendor": "unknown",
    "executables": false,
    "linker-flavor": "gcc",
    "linker": "i686-elf-gcc",
    "pre-link-args": {
        "gcc": [
            "-m32",
            "-nostdlib",
            "-ffreestanding"
        ]
    },
    "panic-strategy": "abort",
    "disable-redzone": true,
    "features": "-mmx,-sse"
}